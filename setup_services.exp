#!/usr/bin/expect -f
set timeout 120
spawn ssh -o StrictHostKeyChecking=no root@173.199.93.201 "cd /root/revns/revns && git pull && docker exec -i revns-scylla cqlsh < infra/init.cql && docker exec revns-redis redis-cli ping"
expect "*?assword:*" {
    send {4{yW+.[7*F[#BP}(}
    send "\r"
}
expect eof
