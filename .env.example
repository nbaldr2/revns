# REVNS VPS Deployment Configuration
# Copy this file to .env and fill in your values

# Redis Configuration
REDIS_PASSWORD=

# ClickHouse Configuration (optional)
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=your_secure_password

# Grafana Configuration
GRAFANA_PASSWORD=your_admin_password

# API Configuration
LOG_LEVEL=info

# Domain (for SSL with Let's Encrypt)
DOMAIN=your-domain.com
EMAIL=your-email@example.com

# ScyllaDB Configuration (advanced)
SCYLLA_SMP=2
SCYLLA_MEMORY=4G

# Backup (optional)
BACKUP_ENABLED=false
BACKUP_S3_BUCKET=your-s3-bucket
BACKUP_AWS_ACCESS_KEY=
BACKUP_AWS_SECRET_KEY=
