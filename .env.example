# REVNS VPS Deployment Configuration
# Copy this file to .env and fill in your values

# Redis Configuration
REDIS_PASSWORD=
REDIS_ADDR=127.0.0.1:6379

# ClickHouse Configuration (optional - for analytics)
CLICKHOUSE_ADDR=127.0.0.1:9000
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
USE_CLICKHOUSE_ANALYTICS=true
USE_CLICKHOUSE_LARGE_NS=true

# ScyllaDB Configuration
SCYLLA_HOSTS=127.0.0.1
SCYLLA_KEYSPACE=domain_data

# Grafana Configuration
GRAFANA_PASSWORD=admin

# API Configuration
LOG_LEVEL=info

# Domain (for SSL with Let's Encrypt)
DOMAIN=your-domain.com
EMAIL=your-email@example.com

# ScyllaDB Configuration (advanced)
SCYLLA_SMP=2
SCYLLA_MEMORY=4G

# Backup (optional)
BACKUP_ENABLED=false
BACKUP_S3_BUCKET=your-s3-bucket
BACKUP_AWS_ACCESS_KEY=
BACKUP_AWS_SECRET_KEY=
